APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# In PRODUKTION setzen (nur über HTTPS gültig): schützt das Session-Cookie.
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
# retry_after MUSS groesser als das laengste Job-Timeout sein (AnalyzeDocumentJob=300s)
DB_QUEUE_RETRY_AFTER=360

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Token für die WordPress-Website-Anfrage-API (fail-closed: ohne Wert
# werden unauthentifizierte Anfragen abgelehnt).
INQUIRY_TOKEN=

# lexoffice (Provisionsbelege, Kontakt-/Rechnungs-Sync). Kann auch über
# admin/settings gepflegt werden; DB-Wert hat Vorrang vor diesem Env.
LEXOFFICE_API_KEY=

# E-Mail-Postfächer per OAuth (Gmail / Microsoft 365). Ohne Werte sind
# nur IMAP/Hostinger-Postfächer nutzbar; OAuth-Konten melden dann klar
# "nicht konfiguriert". Redirect-URI: <APP_URL>/admin/email-accounts/oauth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common

# KI-gestützte E-Mail-Auswertung (optional). Ohne Key bleibt die
# Verarbeitung voll funktionsfähig; die KI-Vorschlagsstufe ist inaktiv.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
# Optionales eigenes Modell fuer die Dokument-Analyse (Vision/PDF)
ANTHROPIC_DOCUMENT_MODEL=
# Austauschbarer KI-Anbieter fuer den Smart Document Upload (aktuell nur "claude")
AI_DOCUMENT_PROVIDER=claude
# Austauschbarer LLM-Anbieter der AI-Workflow-Engine (aktuell nur "claude";
# spaeter openai/gemini/azure ohne Engine-Aenderung)
AI_TEXT_PROVIDER=claude

# Kostenlose OCR-Basisebene (Tesseract) fuer den Smart Document Upload:
# erst nach "apt install tesseract-ocr tesseract-ocr-deu poppler-utils"
# auf dem Server aktivieren (siehe CLAUDE.md).
OCR_ENABLED=false
OCR_LANGUAGES=deu+eng
# Leistungsgrenzen fuer OCR (schuetzen vor Timeouts auf schwacher Hardware):
# DPI der PDF-Rasterung, max. OCR-Seiten, hartes Gesamt-Zeitbudget (Sek.),
# Timeout je Seite. Reicht OCR im Budget nicht, eskaliert das System zur KI.
OCR_DPI=150
OCR_MAX_PAGES=10
OCR_MAX_SECONDS=60
OCR_PAGE_TIMEOUT=20
